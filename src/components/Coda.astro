---
// Coda — closing tagline + 3 profile chips.
// ADR-021 — switched chips to the shared .chip utility for visual
// parity with OnTheWork DDD links. The previously-proposed
// "built by hand · no third-party trackers" mono footer was dropped
// during the design chat review (felt over-labeled).

const links = [
  { href: 'https://github.com/rquader', label: 'github', icon: '↗' },
  { href: 'https://www.linkedin.com/in/rafan-quader/', label: 'linkedin', icon: '↗' },
  { href: 'mailto:rafan.quader@sjsu.edu', label: 'email', icon: '✉' },
] as const;
---
<section class="section coda" id="coda" data-section-id="coda">
  <div class="section-inner">
    <p class="tagline tagline-primary">Computer Science @ SJSU</p>
    <p class="tagline tagline-secondary">
      Research · Claude Code · Education
    </p>
    <div class="coda-links">
      {
        links.map(({ href, label, icon }) => (
          <a
            class="chip"
            href={href}
            target={href.startsWith('mailto:') ? undefined : '_blank'}
            rel={href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
          >
            <span class="chip-icon" aria-hidden="true">{icon}</span>
            <span>{label}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .coda {
    border-top: 1px solid var(--hair);
    padding-bottom: clamp(6rem, 12vh, 10rem);
  }

  .coda .tagline-primary {
    font-family: var(--face-display);
    font-variation-settings: 'SOFT' 70, 'WONK' 0;
    font-size: var(--type-body);
    line-height: var(--leading-body);
    max-width: var(--max-content);
    color: var(--text-0);
    margin: 0 0 0.3rem;
  }

  .coda .tagline-secondary {
    font-family: var(--face-text);
    font-size: var(--type-small);
    color: var(--text-2);
    margin: 0 0 1.3rem;
  }

  .coda-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
</style>
