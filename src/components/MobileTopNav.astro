---
/**
 * MobileTopNav.astro
 *
 * Phone shell top-nav: brand + menu icon + slide-in drawer.
 * Visible only at <=720px (gated by `data-shell="mobile"` on the
 * wrapper element). On desktop, the existing TopNav.astro renders.
 *
 * The drawer holds the same five home-page section anchors as the
 * desktop nav, plus a projects route link, theme toggle, and github
 * pill. Hash routes work identically across shells because the
 * underlying section IDs are unchanged (#threshold, #on-me, etc.).
 *
 * Spec: [[decisions/ADR-021-desktop-overhaul-and-dual-shell-mobile]];
 *       [[Mobile/00 - Mobile Track Overview]].
 */

const pathname = Astro.url.pathname;
const BASE = import.meta.env.BASE_URL;
const BASE_WITH_SLASH = BASE.endsWith('/') ? BASE : `${BASE}/`;
const BASE_NO_SLASH = BASE_WITH_SLASH.replace(/\/$/, '');

const projectsPath = `${BASE_NO_SLASH}/projects`;
const onProjects = pathname === projectsPath || pathname.startsWith(`${projectsPath}/`);

const withBase = (p: string) => `${BASE_WITH_SLASH}${p.replace(/^\//, '')}`;
const homeHref = onProjects ? `${BASE_WITH_SLASH}#threshold` : '#threshold';

type DrawerLink = {
  slug: string;
  label: string;
  href: string;
  route?: boolean;
};

const drawerLinks: DrawerLink[] = [
  { slug: 'on-me', label: 'on me', href: onProjects ? `${BASE_WITH_SLASH}#on-me` : '#on-me' },
  { slug: 'on-the-work', label: 'on the work', href: onProjects ? `${BASE_WITH_SLASH}#on-the-work` : '#on-the-work' },
  { slug: 'projects', label: 'projects', href: withBase('/projects/'), route: true },
  { slug: 'on-the-trail', label: 'on the trail', href: onProjects ? `${BASE_WITH_SLASH}#on-the-trail` : '#on-the-trail' },
  { slug: 'coda', label: 'on the web', href: onProjects ? `${BASE_WITH_SLASH}#coda` : '#coda' },
];
---
<div class="scroll-progress" aria-hidden="true" data-shell="mobile"></div>
<header
  class="mobile-top-nav"
  data-shell="mobile"
  aria-label="primary"
>
  <a
    class="mobile-top-nav-home"
    href={homeHref}
    data-nav-link="threshold"
    aria-label="home"
  >rq</a>
  <span class="mobile-top-nav-route" aria-hidden="true">
    {onProjects ? 'projects' : ''}
  </span>
  <div class="mobile-top-nav-actions">
    <button
      class="mobile-top-nav-iconbtn"
      type="button"
      data-drawer-open
      aria-label="open menu"
      aria-controls="mobile-drawer"
      aria-expanded="false"
    >
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" />
      </svg>
    </button>
  </div>
</header>

<div
  class="mobile-drawer-scrim"
  data-shell="mobile"
  data-drawer-scrim
  aria-hidden="true"
></div>
<aside
  id="mobile-drawer"
  class="mobile-drawer"
  data-shell="mobile"
  aria-label="navigation drawer"
  aria-hidden="true"
  hidden
>
  <div class="mobile-drawer-head">
    <span class="mobile-drawer-eyebrow">menu</span>
    <button
      type="button"
      class="mobile-drawer-close"
      data-drawer-close
      aria-label="close menu"
    >×</button>
  </div>

  <nav class="mobile-drawer-links" aria-label="home sections">
    {drawerLinks.map(({ slug, label, href, route }) => (
      <a
        class:list={[
          'mobile-drawer-link',
          { 'is-active': route && onProjects },
        ]}
        href={href}
        data-nav-link={slug}
        data-drawer-link
        {...route && onProjects ? { 'aria-current': 'page' } : {}}
      >
        <span>{label}</span>
        {route && <span class="mobile-drawer-link-arrow" aria-hidden="true">↗</span>}
      </a>
    ))}
  </nav>

  <div class="mobile-drawer-foot">
    <div class="mobile-drawer-foot-row">
      <span class="mobile-drawer-foot-label">theme</span>
      <div class="mobile-theme-seg" role="group" aria-label="color scheme">
        <button
          type="button"
          class="mobile-theme-btn"
          data-theme-set="light"
          aria-label="light theme"
        >light</button>
        <button
          type="button"
          class="mobile-theme-btn"
          data-theme-set="dark"
          aria-label="dark theme"
        >dark</button>
      </div>
    </div>
    <a
      class="mobile-drawer-github"
      href="https://github.com/rquader"
      target="_blank"
      rel="noopener noreferrer"
    >
      github ↗
    </a>
  </div>
</aside>

<style>
  .mobile-top-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--nav-h);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    padding: 0 var(--gutter);
    z-index: 50;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--bg-0) 92%, transparent) 0%,
      color-mix(in srgb, var(--bg-0) 60%, transparent) 70%,
      transparent 100%
    );
    backdrop-filter: blur(6px) saturate(110%);
    -webkit-backdrop-filter: blur(6px) saturate(110%);
    pointer-events: none;
  }
  .mobile-top-nav a,
  .mobile-top-nav button { pointer-events: auto; }

  .mobile-top-nav-home {
    font-family: var(--face-display);
    font-variation-settings: 'SOFT' 60, 'WONK' 0;
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    color: var(--text-0);
    text-decoration: none;
    font-weight: 500;
  }

  .mobile-top-nav-route {
    justify-self: center;
    font-family: var(--face-mono);
    font-size: 0.74rem;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--text-2);
    text-transform: lowercase;
  }

  .mobile-top-nav-actions {
    justify-self: end;
  }
  .mobile-top-nav-iconbtn {
    width: var(--tap-min);
    height: var(--tap-min);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    color: var(--text-0);
    cursor: pointer;
    border-radius: 50%;
    transition: background var(--d-fast) var(--ease-out);
  }
  .mobile-top-nav-iconbtn:hover,
  .mobile-top-nav-iconbtn:focus-visible {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    outline: none;
  }

  /* Drawer scrim — soft dark wash over the page when drawer is open. */
  .mobile-drawer-scrim {
    position: fixed;
    inset: 0;
    background: var(--scrim);
    z-index: 70;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--d-med) var(--ease-out);
  }
  .mobile-drawer-scrim[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  /* Drawer panel — slides in from the right. */
  .mobile-drawer {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: min(86vw, 22rem);
    z-index: 80;
    background: var(--bg-1);
    border-left: 1px solid var(--hair);
    box-shadow: var(--shadow-floating);
    padding: env(safe-area-inset-top, 0) clamp(1.1rem, 4vw, 1.6rem) env(safe-area-inset-bottom, 0);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transform: translateX(100%);
    transition: transform var(--d-med) var(--ease-out);
  }
  .mobile-drawer[data-open="true"] {
    transform: translateX(0);
  }

  .mobile-drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: clamp(0.8rem, 3vw, 1.1rem) 0 0.4rem;
    border-bottom: 1px solid var(--hair);
  }
  .mobile-drawer-eyebrow {
    font-family: var(--face-mono);
    font-size: var(--type-tiny);
    letter-spacing: var(--tracking-eyebrow);
    color: var(--text-2);
    text-transform: lowercase;
  }
  .mobile-drawer-close {
    width: var(--tap-min);
    height: var(--tap-min);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    border-radius: 50%;
    color: var(--text-1);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    transition: background var(--d-fast) var(--ease-out);
  }
  .mobile-drawer-close:hover,
  .mobile-drawer-close:focus-visible {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    outline: none;
  }

  .mobile-drawer-links {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding-top: 0.4rem;
  }
  .mobile-drawer-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: var(--tap-min);
    padding: 0.7rem 0.4rem;
    text-decoration: none;
    color: var(--text-1);
    font-family: var(--face-display);
    font-variation-settings: 'SOFT' 60, 'WONK' 0;
    font-size: 1.18rem;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 8%, transparent);
    transition:
      color var(--d-fast) var(--ease-out),
      background var(--d-fast) var(--ease-out);
  }
  .mobile-drawer-link:hover,
  .mobile-drawer-link:focus-visible,
  .mobile-drawer-link.is-active {
    color: var(--text-0);
    outline: none;
  }
  .mobile-drawer-link.is-current {
    color: var(--accent);
    font-style: italic;
  }
  .mobile-drawer-link-arrow {
    font-family: var(--face-mono);
    font-size: 0.85rem;
    color: var(--text-2);
  }

  .mobile-drawer-foot {
    margin-top: auto;
    padding: 1rem 0 1.5rem;
    border-top: 1px solid var(--hair);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .mobile-drawer-foot-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .mobile-drawer-foot-label {
    font-family: var(--face-mono);
    font-size: var(--type-tiny);
    letter-spacing: var(--tracking-eyebrow);
    color: var(--text-2);
    text-transform: lowercase;
  }

  .mobile-theme-seg {
    display: inline-flex;
    background: var(--bg-2);
    border: 1px solid var(--hair);
    border-radius: 999px;
    padding: 2px;
  }
  .mobile-theme-btn {
    min-width: 3.5rem;
    padding: 0.35rem 0.7rem;
    background: transparent;
    border: 0;
    color: var(--text-2);
    font-family: var(--face-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    cursor: pointer;
    border-radius: 999px;
    transition:
      background var(--d-fast) var(--ease-out),
      color var(--d-fast) var(--ease-out);
  }
  :root[data-theme="light"] .mobile-theme-btn[data-theme-set="light"] {
    background: var(--accent);
    color: var(--bg-0);
  }
  :root[data-theme="dark"] .mobile-theme-btn[data-theme-set="dark"] {
    background: var(--accent);
    color: var(--bg-0);
  }

  .mobile-drawer-github {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.9rem;
    background: var(--accent);
    color: var(--bg-0);
    border-radius: 4px;
    font-family: var(--face-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    text-decoration: none;
    transition: transform var(--d-fast) var(--ease-out), background var(--d-fast) var(--ease-out);
  }
  .mobile-drawer-github:hover,
  .mobile-drawer-github:focus-visible {
    transform: translateY(-1px);
    background: color-mix(in srgb, var(--accent) 92%, var(--text-0));
    outline: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-drawer,
    .mobile-drawer-scrim {
      transition: none;
    }
  }
</style>
