---
// Base.astro — single layout for every page in src/pages/*.
//
// Responsibilities:
//   - <html>, <head>, viewport + description meta
//   - global stylesheet wiring (tokens + global)
//   - a skip-link affordance for keyboard users
//   - the rAF boot script (wired in Bootstrap step 3.2; placeholder until then)
//
// Spec: [[02 - Architecture]].

import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/falling-leaves.css';
import '../styles/obsidian-notes.css';
import '../styles/photo.css';
import '../styles/tree-hint.css';
import '../styles/projects.css';
import '../styles/notes-popup.css';
import '../styles/wip-dialog.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Rafan Quader — portfolio',
  description =
    'Computer Science @ SJSU. Aspiring to participate in meaningful ' +
    'applications of Computer Science.',
} = Astro.props;

const canonical = Astro.url.href;

// ADR-025 — fonts.css lives in public/fonts/ (not src/styles/) so its
// @font-face URLs can stay relative (`url(./<hash>.woff2)`) and resolve
// correctly under any base path (GitHub Pages project pages serve under
// `/<repo>/`). The Astro `import` style would bundle the CSS into
// `_astro/` and the relative URLs would resolve against that location
// instead — wrong. Link the file explicitly with the BASE_URL prefix.
const BASE_WITH_SLASH = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const fontsHref = `${BASE_WITH_SLASH}fonts/fonts.css`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    {/* ADR-025 — fonts are self-hosted via public/fonts/*.woff2; the
        @font-face declarations live in public/fonts/fonts.css with
        relative URLs so the path resolves correctly under any base
        (GitHub Pages project pages serve under `/<repo>/`). No
        third-party request at runtime. Acquisition / refresh:
        `bash scripts/get-fonts.sh`.

        Preload hints for above-the-fold fonts so they are fetched in
        parallel with (not after) the fonts.css stylesheet parse.
        crossorigin is required even for same-origin font fetches — the
        browser issues font requests in CORS mode, and a mismatched
        credentials mode causes a duplicate fetch. */}
    <link rel="preload" as="font" type="font/woff2" crossorigin
      href={`${BASE_WITH_SLASH}fonts/6NUG8FyLNQOQZAnv9ZwNjucMAkn8xNi7emAe9nimTfdtuFo2.woff2`} />
    <link rel="preload" as="font" type="font/woff2" crossorigin
      href={`${BASE_WITH_SLASH}fonts/cY9AfjOCX1hbuyalUrK4397yjIJFJpc.woff2`} />
    <link rel="preload" as="font" type="font/woff2" crossorigin
      href={`${BASE_WITH_SLASH}fonts/tDbv2o-flEEny0FZhsfKu5WU4zr3E_BX0PnT8RD8yKwBNntkaToggR7BYRbKPxDcwgknk-4.woff2`} />

    {/* fonts.css loaded async so it is non-render-blocking. The preloads
        above ensure the three above-fold woff2 files are already in
        flight before the @font-face rules are even parsed. font-display:
        swap (set in fonts.css) handles the remaining swap window. The
        <noscript> fallback restores synchronous loading for the small
        fraction of users with JS disabled. */}
    <link rel="stylesheet" href={fontsHref} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={fontsHref} /></noscript>

    {/* FOUC-prevention: sets data-theme on <html> before first paint.
        Reads rq-theme from localStorage; default is light. Matches the
        choice in ADR-009 (light default, dark via toggle — OS pref is
        not consulted; the toggle is the only mechanism). */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('rq-theme');
          var theme = (stored === 'dark') ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', theme);
        } catch (_) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>

    {/* Inline SVG favicon — a single "rq" lowercase mark in the FOREST-accent tone. */}
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='10' fill='%230A1620'/%3E%3Ctext x='32' y='44' text-anchor='middle' font-family='Georgia,serif' font-size='34' fill='%23B0EBD2'%3Erq%3C/text%3E%3C/svg%3E"
    />

    {/* OpenGraph / Twitter cards */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href={canonical} />
  </head>
  <body>
    {/* Page-wide drifting-leaf backdrop. Behind the threshold tree
        (which is z-index: -1 within its section). Spec:
        [[specs/2026-05-18-tree-leaves-folders-design#4.1]]. */}
    <canvas id="page-leaves" class="page-leaves-bg" aria-hidden="true"></canvas>
    <a class="skip-link" href="#on-me">skip to content</a>
    <div id="section-live" class="visually-hidden" aria-live="polite" aria-atomic="true"></div>
    <slot />

    <div
      id="photo-lightbox"
      class="photo-lightbox"
      data-state="closed"
      role="dialog"
      aria-modal="true"
      aria-label="enlarged photograph"
      aria-hidden="true"
    >
      <button class="photo-lightbox-close" type="button" aria-label="close">×</button>
      <img class="photo-lightbox-image" src="" alt="" />
    </div>

    <script>
      // Single client-side entry point. Starts the rAF loop and inits
      // every primitive against whatever's in the DOM. Each init is a
      // no-op if its target markup is absent — so per-page opt-in is
      // "just include the right elements."
      // See: src/lib/site-init.ts and 02 - Architecture.
      import { initSite } from '../lib/site-init';
      initSite();
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    padding: 0.5rem 1rem;
    background: var(--paper-0);
    color: var(--ink-0);
    z-index: 200;
    font-size: var(--type-small);
  }
  .skip-link:focus {
    left: 0;
  }
</style>
