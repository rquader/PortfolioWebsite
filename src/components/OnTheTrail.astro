---
// On The Trail — coursework, tools, resume.
// ADR-021 — coursework items linked to SJSU catalog pages (new tab),
// styled to be visually identical to plain list items: no underline at
// rest, hover dotted-underline, focus accent. Resume button switches to
// the shared .btn-accent utility.

const BASE = import.meta.env.BASE_URL;
const BASE_WITH_SLASH = BASE.endsWith('/') ? BASE : `${BASE}/`;
const resumeHref = `${BASE_WITH_SLASH}Rafan_Quader_Resume.pdf`;

// SJSU catalog URLs — verbatim from the design handoff's m/data.js
// (Discrete Math + Intro to Data Structures share coid=44161; if that's
// a paste error in the source, replace with the canonical Discrete Math
// course URL next pass.)
const courses: Array<{ label: string; href: string }> = [
  {
    label: 'Data Structures & Algorithms',
    href: 'https://catalog.sjsu.edu/preview_course_nopop.php?catoid=10&coid=42151',
  },
  {
    label: 'Discrete Math',
    href: 'https://catalog.sjsu.edu/preview_course_nopop.php?catoid=10&coid=44161',
  },
  {
    label: 'Intro to Data Structures',
    href: 'https://catalog.sjsu.edu/preview_course_nopop.php?catoid=10&coid=44161',
  },
  {
    label: 'Talking Back to Research: Critical Skills for Leaders',
    href: 'https://catalog.sjsu.edu/preview_course_nopop.php?catoid=13&coid=122976',
  },
];

const tools: string[] = ['Java', 'Git', 'Claude Code / Cursor', 'Obsidian'];
---
<section
  class="section on-the-trail"
  id="on-the-trail"
  data-section-id="on-the-trail"
>
  <div class="section-inner">
    <h2 class="section-heading" data-color-letters data-inertial-text>on the trail</h2>

    <div class="trail-groups">
      <div class="group">
        <h3>coursework so far</h3>
        <ul>
          {courses.map(({ label, href }) => (
            <li>
              <a
                class="trail-link"
                href={href}
                target="_blank"
                rel="noopener noreferrer"
              >{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="group">
        <h3>tools</h3>
        <ul>
          {tools.map((t) => <li>{t}</li>)}
        </ul>
      </div>
    </div>

    <a class="btn-accent" href={resumeHref} download type="application/pdf">
      <span class="ico" aria-hidden="true">↓</span>
      <span>resume (PDF)</span>
    </a>
  </div>
</section>

<style>
  .trail-groups {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 56rem;
    margin-bottom: 2rem;
  }
  .trail-groups h3 {
    font-family: var(--face-display);
    font-variation-settings: 'SOFT' 70, 'WONK' 1;
    font-style: italic;
    font-size: 1.2rem;
    margin-bottom: 0.6rem;
  }
  .trail-groups ul {
    list-style: none;
    padding: 0;
  }
  .trail-groups li {
    padding: 0.45rem 0 0.45rem 1.1rem;
    color: var(--text-1);
    font-size: var(--type-body);
    border-bottom: 1px solid var(--hair);
    position: relative;
  }
  .trail-groups li::before {
    content: '·';
    position: absolute;
    left: 0.15rem;
    top: 0.45rem;
    color: var(--accent);
    font-family: var(--face-mono);
    font-weight: 700;
  }

  /* Quietly-linked coursework items — same color/weight as plain text;
     underline whispers on hover, accent-tinted on focus. */
  .trail-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      color var(--d-fast) var(--ease-out),
      border-color var(--d-fast) var(--ease-out);
  }
  .trail-link:hover {
    color: var(--text-0);
    border-bottom-color: color-mix(in srgb, var(--accent) 50%, transparent);
  }
  .trail-link:focus-visible {
    color: var(--accent);
    border-bottom-color: var(--accent);
    outline: none;
  }
</style>
