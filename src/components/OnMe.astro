---
// On Me — bio with synesthesia hover-coloring on selected words.
// ADR-021: adds a quiet field-card sidebar on the right at ≥880px
// (education + focus / tools / club rows in JetBrains Mono). On phone
// widths the Threshold photo is hidden and rendered here instead
// (data-shell="mobile"), giving Threshold the full hero width.

import Photo from './photo/Photo.astro';

import fs from 'node:fs';
import path from 'node:path';

const BASE = import.meta.env.BASE_URL;
const BASE_WITH_SLASH = BASE.endsWith('/') ? BASE : `${BASE}/`;
const photoPublicPath = '/images/rafan-speaking-1.jpg';
const photoDiskPath = path.join(process.cwd(), 'public', photoPublicPath);
const hasPhoto = fs.existsSync(photoDiskPath);
---
<section class="section on-me" id="on-me" data-section-id="on-me">
  <div class="section-inner">
    <h2 class="section-heading" data-color-letters data-inertial-text>on me</h2>

    {/* Mobile-only photo: only shows in the mobile shell (<=720px).
        The Threshold photo carries it on desktop. Includes the small
        caption pill "rafan, speaking" per the design (m/sections.jsx). */}
    <div class="on-me-photo" data-shell="mobile">
      <Photo
        src={`${BASE_WITH_SLASH}${(hasPhoto ? photoPublicPath : '/images/rafan-speaking-1.svg').replace(/^\//, '')}`}
        alt="Rafan Quader speaking at an event"
        treatment="print"
        aspect="1/1"
      />
      <span class="on-me-photo-cap" aria-hidden="true">rafan, speaking</span>
    </div>

    <div class="bio">
      <p class="bio-lead">
        As a student beginning in <strong>Computer Science</strong>, one thing I can say in
        <em>high confidence</em>:
        <span data-syn-word>massive change</span> is not only imminent but in fast motion.
      </p>
      <p>
        In that change, people can, like much other change, push towards a
        <span data-syn-word>better world</span> or break it down as we know it. For me, that
        makes my goal discovering the fields I am most interested in and joining initiatives
        utilizing this program to participate in <span data-syn-word>meaningful</span>
        endeavors, build things, or simply message <span data-syn-word>Claude Code</span>.
      </p>
    </div>

    {/* Quiet sidebar — quick facts, JetBrains Mono labels.
        TODO (next session): move education / focus / tools / club into
        the content collection so the user can edit without touching
        components (see [[Mobile/Known Issue — Use real sanitized notes
        (not placeholder)]] for the pattern). */}
    <aside class="on-me-field" aria-label="quick facts">
      <span class="on-me-field-eyebrow">at a glance</span>
      <h3>field card</h3>
      <p class="on-me-field-meta">
        B.S. <strong>Computer Science</strong>, San José State University
        (Aug 2025 &ndash; May 2029).
      </p>
      <div class="on-me-field-row"><span>focus</span><span>research · education · presentation</span></div>
      <div class="on-me-field-row"><span>tools</span><span>java · git · claude code</span></div>
      <div class="on-me-field-row"><span>club</span><span>SCE @ SJSU</span></div>
    </aside>
  </div>
</section>

<style>
  /* Two-column on wide viewports; bio + field card. The heading spans
     both columns at the top. */
  .on-me .section-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 22rem);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .on-me .section-heading { grid-column: 1 / -1; }
  .on-me .on-me-photo { grid-column: 1 / -1; }
  @media (max-width: 880px) {
    .on-me .section-inner { grid-template-columns: 1fr; }
  }

  /* Mobile photo wrapper — frame, 1:1 crop, caption pill at bottom-left
     (mirrors m/sections.css .on-me-photo-card). */
  .on-me-photo {
    position: relative;
    width: 100%;
    max-width: 22rem;
    aspect-ratio: 1 / 1;
    margin: 0.2rem 0 1.4rem;
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg-1);
    border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
    box-shadow: var(--shadow-card);
  }
  .on-me-photo .photo,
  .on-me-photo .photo-picture {
    width: 100%;
    height: 100%;
    aspect-ratio: 1 / 1;
    box-shadow: none;
  }
  .on-me-photo .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 40%;
  }
  .on-me-photo-cap {
    position: absolute;
    left: 0.65rem;
    bottom: 0.55rem;
    padding: 0.22rem 0.55rem;
    font-family: var(--face-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    color: var(--text-0);
    background: color-mix(in srgb, var(--bg-0) 78%, transparent);
    border-radius: 3px;
    pointer-events: none;
  }

  .on-me .bio {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    max-width: 38rem;
  }

  .on-me .bio p {
    margin: 0;
    font-family: var(--face-text);
    font-size: clamp(1.05rem, 0.35vw + 1rem, 1.18rem);
    line-height: 1.72;
    letter-spacing: 0.01em;
    color: var(--text-1);
    max-width: none;
  }

  .on-me .bio-lead {
    font-family: var(--face-display);
    font-variation-settings: 'SOFT' 75, 'WONK' 0;
    font-size: clamp(1.15rem, 0.5vw + 1.05rem, 1.32rem);
    line-height: 1.6;
    color: var(--text-0);
  }

  .on-me .bio strong {
    font-weight: 600;
    color: var(--text-0);
  }

  .on-me .bio em {
    font-style: italic;
    font-variation-settings: 'SOFT' 90;
    color: color-mix(in srgb, var(--text-0) 88%, var(--accent));
  }

  /* Field card — quiet hairline border + half-tinted bg-1 panel,
     mono labels separated by hairline dividers (last row no border). */
  .on-me-field {
    border: 1px solid var(--hair);
    border-radius: 4px;
    padding: 1.3rem 1.4rem;
    background: color-mix(in srgb, var(--bg-1) 50%, transparent);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .on-me-field-eyebrow {
    font-family: var(--face-mono);
    font-size: var(--type-tiny);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: lowercase;
    color: var(--text-2);
  }
  .on-me-field h3 {
    font-family: var(--face-display);
    font-variation-settings: 'SOFT' 75, 'WONK' 0;
    font-size: 1.1rem;
    font-style: italic;
    color: var(--text-0);
    margin: 0;
  }
  .on-me-field-meta {
    font-family: var(--face-text);
    font-size: 0.94rem;
    color: var(--text-1);
    line-height: 1.6;
    max-width: none;
    margin: 0;
  }
  .on-me-field-meta strong { color: var(--text-0); font-weight: 600; }
  .on-me-field-row {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    font-family: var(--face-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--text-2);
    text-transform: lowercase;
    padding: 0.25rem 0;
    border-bottom: 1px solid var(--hair);
  }
  .on-me-field-row:last-child { border-bottom: 0; }
  .on-me-field-row span:last-child { color: var(--text-1); }

  :root[data-theme="dark"] .on-me {
    background-color: rgb(
      calc(20 + var(--syn-r, 200) * 0.06),
      calc(18 + var(--syn-g, 180) * 0.06),
      calc(16 + var(--syn-b, 160) * 0.06)
    );
    transition: background-color 1.2s ease;
  }
  :root[data-theme="dark"] .on-me.syn-tinted {
    background-color: rgb(
      calc(30 + var(--syn-r) * 0.22),
      calc(27 + var(--syn-g) * 0.22),
      calc(24 + var(--syn-b) * 0.22)
    );
  }
</style>
